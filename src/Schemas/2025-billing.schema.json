{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "badDebtPercent": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{2}%$",
      "description": "Percentage with 2 decimal places and % suffix (e.g. 6.00%)"
    },
    "cost": {
      "type": "string",
      "pattern": "^-?[0-9]+\\.[0-9]{2}$",
      "description": "GBP cost, 2 decimal places, no £ prefix (e.g. \"1234.56\")"
    },
    "costOrNull": {
      "type": ["string", "null"],
      "pattern": "^-?[0-9]+\\.[0-9]{2}$",
      "description": "GBP cost, 2 decimal places, no £ prefix, or null when not applicable"
    },
    "pricePerTonne": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{4}$",
      "description": "Price per tonne, 4 decimal places, no £ prefix (e.g. \"0.2105\")"
    },
    "feeWithCountries": {
      "type": "object",
      "description": "A fee breakdown: base amount, bad debt provision, total (with bad debt), and country splits",
      "required": ["base", "badDebtProvision", "total", "england", "wales", "scotland", "northernIreland"],
      "properties": {
        "base":             { "$ref": "#/$defs/cost" },
        "badDebtProvision": { "$ref": "#/$defs/cost" },
        "total":            { "$ref": "#/$defs/cost" },
        "england":          { "$ref": "#/$defs/cost" },
        "wales":            { "$ref": "#/$defs/cost" },
        "scotland":         { "$ref": "#/$defs/cost" },
        "northernIreland":  { "$ref": "#/$defs/cost" }
      }
    },
    "ragPricePerTonne": {
      "type": "object",
      "description": "Price per tonne split by combined RAG pairs",
      "required": ["redAndRedMedical", "amberAndAmberMedical", "greenAndGreenMedical"],
      "properties": {
        "redAndRedMedical":     { "$ref": "#/$defs/pricePerTonne" },
        "amberAndAmberMedical": { "$ref": "#/$defs/pricePerTonne" },
        "greenAndGreenMedical": { "$ref": "#/$defs/pricePerTonne" }
      }
    }
  },
  "type": "object",
  "required": ["calcResultDetail", "parametersOther", "producers", "materials"],
  "properties": {
    "calcResultDetail": {
      "type": "object",
      "required": ["runId", "financialYear"],
      "properties": {
        "runId": { "type": "integer" },
        "financialYear": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$",
          "description": "Financial year in YYYY-YY format (e.g. 2026-27)"
        }
      }
    },
    "parametersOther": {
      "type": "object",
      "required": ["sixBadDebtProvision"],
      "properties": {
        "sixBadDebtProvision": {
          "type": "object",
          "required": ["percentage"],
          "properties": {
            "percentage": { "$ref": "#/$defs/badDebtPercent" }
          }
        }
      }
    },
    "modulationResults": { "type": "null" },
    "materials": {
      "type": "array",
      "description": "Run-level per-material price data; same for all producers — join by materialName",
      "items": {
        "type": "object",
        "required": ["materialName", "disposalPricePerTonne", "commsPricePerTonne"],
        "properties": {
          "materialName":          { "type": "string" },
          "disposalPricePerTonne": { "$ref": "#/$defs/ragPricePerTonne" },
          "commsPricePerTonne":    { "$ref": "#/$defs/pricePerTonne" }
        }
      }
    },
    "producers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "producerName", "producerID", "subsidiaryID", "level",
          "totalBill", "invoice",
          "disposalFeesByMaterial",
          "disposalCosts",
          "commsCostsByMaterial",
          "commsCostsUKWide",
          "commsCostsByCountry",
          "saOperatingCosts",
          "laDataPrepCosts",
          "saSetUpCosts"
        ],
        "properties": {
          "producerName": { "type": "string" },
          "producerID":   { "type": "string" },
          "subsidiaryID": { "type": "string" },
          "level":        { "type": "integer" },

          "totalBill": { "$ref": "#/$defs/feeWithCountries" },

          "invoice": {
            "type": "object",
            "required": ["instruction", "suggestedAmount", "invoicedToDate"],
            "properties": {
              "instruction":     { "type": "string" },
              "suggestedAmount": { "$ref": "#/$defs/costOrNull" },
              "invoicedToDate":  { "$ref": "#/$defs/costOrNull" }
            }
          },

          "disposalFeesByMaterial": {
            "type": "array",
            "description": "Per-material tonnage and fee breakdown for LA disposal costs (section 1)",
            "items": {
              "type": "object",
              "required": [
                "materialName",
                "householdPackagingWasteTonnage",
                "publicBinTonnage",
                "totalTonnage",
                "selfManagedConsumerWasteTonnage",
                "netTonnage",
                "feeWithoutBadDebt",
                "badDebtProvision",
                "fee",
                "england", "wales", "scotland", "northernIreland",
                "previousInvoicedTonnage",
                "tonnageChange"
              ],
              "properties": {
                "materialName":                        { "type": "string" },
                "householdPackagingWasteTonnage":       { "type": "number" },
                "publicBinTonnage":                    { "type": "number" },
                "householdDrinksContainersTonnageGlass": { "type": "number" },
                "totalTonnage":                        { "type": "number" },
                "selfManagedConsumerWasteTonnage":      { "type": "number" },
                "netTonnage":                          { "type": "number" },
                "feeWithoutBadDebt":                   { "$ref": "#/$defs/cost" },
                "badDebtProvision":                    { "$ref": "#/$defs/cost" },
                "fee":                                 { "$ref": "#/$defs/cost" },
                "england":                             { "$ref": "#/$defs/cost" },
                "wales":                               { "$ref": "#/$defs/cost" },
                "scotland":                            { "$ref": "#/$defs/cost" },
                "northernIreland":                     { "$ref": "#/$defs/cost" },
                "previousInvoicedTonnage":             { "type": "string" },
                "tonnageChange":                       { "type": "string" }
              }
            }
          },

          "disposalCosts":        { "$ref": "#/$defs/feeWithCountries" },
          "commsCostsByMaterial": { "$ref": "#/$defs/feeWithCountries" },
          "commsCostsUKWide":     { "$ref": "#/$defs/feeWithCountries" },
          "commsCostsByCountry":  { "$ref": "#/$defs/feeWithCountries" },
          "saOperatingCosts":     { "$ref": "#/$defs/feeWithCountries" },
          "laDataPrepCosts":      { "$ref": "#/$defs/feeWithCountries" },
          "saSetUpCosts":         { "$ref": "#/$defs/feeWithCountries" }
        }
      }
    }
  }
}
