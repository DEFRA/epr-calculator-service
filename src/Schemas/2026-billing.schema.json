{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "badDebtPercent": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{2}$",
      "description": "Percentage, 2 decimal places, no % suffix (e.g. \"6.00\")"
    },
    "cost": {
      "type": "string",
      "pattern": "^-?[0-9]+\\.[0-9]{2}$",
      "description": "GBP cost, 2 decimal places, no £ prefix (e.g. \"1234.56\")"
    },
    "costOrNull": {
      "type": ["string", "null"],
      "pattern": "^-?[0-9]+\\.[0-9]{2}$",
      "description": "GBP cost, 2 decimal places, no £ prefix, or null when not applicable"
    },
    "pricePerTonne": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{4}$",
      "description": "Price per tonne, 4 decimal places, no £ prefix (e.g. \"0.2105\")"
    },
    "fee": {
      "type": "object",
      "description": "A fee with base amount and bad debt provision",
      "required": ["base", "badDebtProvision"],
      "properties": {
        "base":             { "$ref": "#/$defs/cost" },
        "badDebtProvision": { "$ref": "#/$defs/cost" }
      }
    },
    "feeWithCountries": {
      "type": "object",
      "description": "A fee breakdown: base amount, bad debt provision, total (with bad debt), and country splits",
      "required": ["base", "badDebtProvision", "total", "england", "wales", "scotland", "northernIreland"],
      "properties": {
        "base":             { "$ref": "#/$defs/cost" },
        "badDebtProvision": { "$ref": "#/$defs/cost" },
        "total":            { "$ref": "#/$defs/cost" },
        "england":          { "$ref": "#/$defs/cost" },
        "wales":            { "$ref": "#/$defs/cost" },
        "scotland":         { "$ref": "#/$defs/cost" },
        "northernIreland":  { "$ref": "#/$defs/cost" }
      }
    },
    "tonnageBreakdown": {
      "type": "object",
      "description": "Tonnage split by RAG rating and medical sub-category",
      "required": ["total", "red", "redMedical", "amber", "amberMedical", "green", "greenMedical"],
      "properties": {
        "total":        { "type": "number" },
        "red":          { "type": "number" },
        "redMedical":   { "type": "number" },
        "amber":        { "type": "number" },
        "amberMedical": { "type": "number" },
        "green":        { "type": "number" },
        "greenMedical": { "type": "number" }
      }
    },
    "ragTonnage": {
      "type": "object",
      "description": "Tonnage split by combined RAG pairs (red+redMedical, amber+amberMedical, green+greenMedical)",
      "required": ["total", "redAndRedMedical", "amberAndAmberMedical", "greenAndGreenMedical"],
      "properties": {
        "total":                { "type": "number" },
        "redAndRedMedical":     { "type": "number" },
        "amberAndAmberMedical": { "type": "number" },
        "greenAndGreenMedical": { "type": "number" }
      }
    },
    "ragCost": {
      "type": "object",
      "description": "Cost split by combined RAG pairs",
      "required": ["total", "redAndRedMedical", "amberAndAmberMedical", "greenAndGreenMedical"],
      "properties": {
        "total":                { "$ref": "#/$defs/cost" },
        "redAndRedMedical":     { "$ref": "#/$defs/cost" },
        "amberAndAmberMedical": { "$ref": "#/$defs/cost" },
        "greenAndGreenMedical": { "$ref": "#/$defs/cost" }
      }
    },
    "ragPricePerTonne": {
      "type": "object",
      "description": "Price per tonne split by combined RAG pairs",
      "required": ["redAndRedMedical", "amberAndAmberMedical", "greenAndGreenMedical"],
      "properties": {
        "redAndRedMedical":     { "$ref": "#/$defs/pricePerTonne" },
        "amberAndAmberMedical": { "$ref": "#/$defs/pricePerTonne" },
        "greenAndGreenMedical": { "$ref": "#/$defs/pricePerTonne" }
      }
    }
  },
  "type": "object",
  "required": ["$schema", "runId", "financialYear", "badDebtProvisionPercentage", "modulationResults", "materials", "producers"],
  "properties": {
    "$schema": { "const": "https://epr.gov.uk/schemas/billing/2026/v1" },
    "runId": { "type": "integer" },
    "financialYear": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$",
      "description": "Financial year in YYYY-YY format (e.g. \"2026-27\")"
    },
    "badDebtProvisionPercentage": { "$ref": "#/$defs/badDebtPercent" },

    "modulationResults": {
      "type": "object",
      "required": ["redFactor", "greenDiscountFactor"],
      "properties": {
        "redFactor": { "type": "number" },
        "greenDiscountFactor": { "type": "number" }
      }
    },
    "materials": {
      "type": "array",
      "description": "Run-level per-material price data; same for all producers — join by materialName",
      "items": {
        "type": "object",
        "required": ["material", "disposalPricePerTonne", "commsPricePerTonne"],
        "properties": {
          "material":          { "type": "string" },
          "disposalPricePerTonne": { "$ref": "#/$defs/ragPricePerTonne" },
          "commsPricePerTonne":    { "$ref": "#/$defs/pricePerTonne" }
        }
      }
    },
    "producers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "producerName", "producerID", "subsidiaryID", "level",
          "totalBill", "invoice",
          "disposalFeesByMaterial",
          "disposalCosts",
          "commsCostsByMaterial",
          "commsCostsUKWide",
          "commsCostsByCountry",
          "saOperatingCosts",
          "laDataPrepCosts",
          "saSetUpCosts"
        ],
        "properties": {
          "producerName": { "type": "string" },
          "producerID":   { "type": "string" },
          "subsidiaryID": { "type": "string" },
          "level":        { "type": "integer" },

          "totalBill": { "$ref": "#/$defs/cost" },

          "invoice": {
            "type": "object",
            "required": ["instruction", "suggestedAmount", "invoicedToDate"],
            "properties": {
              "instruction":     { "type": "string", "enum": ["", "-", "INITIAL", "DELTA", "REBILL"] },
              "suggestedAmount": { "$ref": "#/$defs/costOrNull" },
              "invoicedToDate":  { "$ref": "#/$defs/costOrNull" }
            }
          },

          "disposalFeesByMaterial": {
            "type": "array",
            "description": "Per-material tonnage and fee breakdown for LA disposal costs (section 1)",
            "items": {
              "type": "object",
              "required": [
                "material",
                "householdPackagingWasteTonnage",
                "publicBinTonnage",
                "totalTonnage",
                "selfManagedConsumerWasteTonnage",
                "actionedSelfManagedConsumerWasteTonnage",
                "netTonnage",
                "feeWithoutBadDebt",
                "badDebtProvision",
                "fee",
                "england", "wales", "scotland", "northernIreland",
                "previousInvoicedTonnage",
                "tonnageChange"
              ],
              "properties": {
                "material":                           { "type": "string" },
                "householdPackagingWasteTonnage":          { "$ref": "#/$defs/tonnageBreakdown" },
                "publicBinTonnage":                       { "$ref": "#/$defs/tonnageBreakdown" },
                "householdDrinksContainersTonnageGlass":  { "$ref": "#/$defs/tonnageBreakdown" },
                "totalTonnage":                           { "$ref": "#/$defs/tonnageBreakdown" },
                "selfManagedConsumerWasteTonnage":         { "type": "number" },
                "actionedSelfManagedConsumerWasteTonnage": { "$ref": "#/$defs/ragTonnage" },
                "residualSelfManagedConsumerWasteTonnage": { "type": "number" },
                "netTonnage":                             { "$ref": "#/$defs/ragTonnage" },
                "feeWithoutBadDebt":                      { "$ref": "#/$defs/ragCost" },
                "badDebtProvision":                       { "$ref": "#/$defs/cost" },
                "fee":                                    { "$ref": "#/$defs/cost" },
                "england":                                { "$ref": "#/$defs/cost" },
                "wales":                                  { "$ref": "#/$defs/cost" },
                "scotland":                               { "$ref": "#/$defs/cost" },
                "northernIreland":                        { "$ref": "#/$defs/cost" },
                "previousInvoicedTonnage":                { "type": "string" },
                "tonnageChange":                          { "type": "string" }
              }
            }
          },

          "disposalCosts":        { "$ref": "#/$defs/feeWithCountries" },
          "commsCostsByMaterial": { "$ref": "#/$defs/fee" },
          "commsCostsUKWide":     { "$ref": "#/$defs/fee" },
          "commsCostsByCountry":  { "$ref": "#/$defs/fee" },
          "saOperatingCosts":     { "$ref": "#/$defs/fee" },
          "laDataPrepCosts":      { "$ref": "#/$defs/fee" },
          "saSetUpCosts":         { "$ref": "#/$defs/fee" }
        }
      }
    }
  }
}
